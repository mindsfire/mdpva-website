---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import Footer from "../components/Footer.astro";

const items = (await getCollection("press")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const dateFmt = new Intl.DateTimeFormat("en-IN", { day: "2-digit", month: "short", year: "numeric" });
---

<Layout
  title="Press"
  description="MDPVA in the media — news coverage of the Mysuru District Photographers and Videographers Association ® in Star of Mysore, Andolana, and other publications."
>
  <Header />
  <PageHero
    eyebrow="In the Media"
    title="MDPVA in the news"
    description="Coverage of the association's events, elections, and members' work in the district press. Articles open on the publisher's site."
  />

  <section class="bg-mdpva-paper px-5 py-[clamp(48px,7vw,90px)] sm:px-8 lg:px-16">
    <div
      class="mx-auto grid max-w-[1200px] gap-6"
      style="grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));"
    >
      {
        items.map((item, i) => (
          <a
            href={item.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col border border-mdpva-border-alt bg-mdpva-white transition-shadow duration-300 hover:shadow-lg"
            data-reveal
            style={`--reveal-delay:${Math.min(i, 5) * 90}ms`}
          >
            <div class="aspect-[4/3] overflow-hidden bg-mdpva-border-tile">
              <img
                src={item.data.thumbnail}
                alt=""
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
              />
            </div>
            <div class="flex flex-1 flex-col gap-3 p-6">
              <div class="flex items-center justify-between gap-3">
                <span class="bg-mdpva-accent/10 px-2.5 py-1 text-[11px] font-semibold tracking-[0.12em] text-mdpva-accent uppercase">
                  {item.data.publication}
                </span>
                <span class="text-[12px] whitespace-nowrap text-mdpva-muted">
                  {dateFmt.format(item.data.date)}
                </span>
              </div>
              <h2 class="text-pretty flex-1 font-serif text-[20px] leading-snug font-medium text-mdpva-ink transition-colors group-hover:text-mdpva-accent">
                {item.data.title}
              </h2>
              <span class="inline-flex items-center gap-1.5 self-start border-b border-current pb-0.5 text-[13px] font-semibold tracking-wide text-mdpva-accent">
                Read the article
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
                  <path d="M7 17L17 7M17 7H8M17 7v9" />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
  <Footer />
</Layout>
