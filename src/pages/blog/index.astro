---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import PageHero from "../../components/PageHero.astro";
import Footer from "../../components/Footer.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const dateFmt = new Intl.DateTimeFormat("en-IN", { day: "2-digit", month: "long", year: "numeric" });
---

<Layout
  title="Blog"
  description="Field notes, craft guides, and association news from the members of the Mysuru District Photographers and Videographers Association ®."
>
  <Header />
  <PageHero
    eyebrow="Blog"
    title="Notes from the field"
    description="Craft guides, gear notes, and association news — written by working members of the district."
  />

  <section class="bg-mdpva-paper px-5 py-[clamp(48px,7vw,90px)] sm:px-8 lg:px-16">
    <div
      class="mx-auto grid max-w-[1200px] gap-8"
      style="grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));"
    >
      {
        posts.map((post, i) => (
          <article
            class="group flex flex-col border border-mdpva-border-alt bg-mdpva-white transition-shadow duration-300 hover:shadow-lg"
            data-reveal
            style={`--reveal-delay:${Math.min(i, 5) * 90}ms`}
          >
            <a href={`/blog/${post.id}`} class="flex h-full flex-col">
              <div class="aspect-[16/9] overflow-hidden bg-mdpva-border-tile">
                <img
                  src={post.data.coverImage}
                  alt=""
                  loading="lazy"
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                />
              </div>
              <div class="flex flex-1 flex-col gap-3 p-6">
                <div class="text-[12px] font-semibold tracking-[0.12em] text-mdpva-accent uppercase">
                  {dateFmt.format(post.data.date)}
                </div>
                <h2 class="text-pretty font-serif text-[22px] leading-tight font-medium text-mdpva-ink transition-colors group-hover:text-mdpva-accent">
                  {post.data.title}
                </h2>
                <p class="flex-1 text-[14px] leading-relaxed text-mdpva-body">{post.data.excerpt}</p>
                <div class="text-[13px] text-mdpva-muted">By {post.data.author}</div>
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </section>
  <Footer />
</Layout>
