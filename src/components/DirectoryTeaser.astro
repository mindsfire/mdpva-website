---
---

<section id="directory" class="bg-mdpva-accent px-5 py-[clamp(56px,9vw,100px)] sm:px-8 lg:px-16">
  <div class="mx-auto flex max-w-[840px] flex-col items-center gap-5.5 text-center" data-reveal>
    <div class="text-xs font-semibold tracking-[0.22em] text-mdpva-cream/72 uppercase">
      Member Directory
    </div>
    <h2 class="text-pretty font-serif text-[clamp(28px,3.6vw,46px)] font-normal text-mdpva-cream">
      Find a photographer or videographer near you
    </h2>
    <p class="max-w-[520px] text-base leading-relaxed text-mdpva-cream/80">
      Every listing is a verified, certified MDPVA member. Search by speciality, taluk, or name.
    </p>
    <form class="mt-2 flex w-full max-w-[520px]" action="/directory" method="get">
      <label class="sr-only" for="directory-search">Search the member directory</label>
      <input
        id="directory-search"
        name="q"
        type="text"
        placeholder="Try “wedding photographer, Nanjangud”"
        class="min-w-0 flex-1 rounded-l-sm border-none bg-mdpva-white px-4.5 py-4 font-sans text-[15px] text-mdpva-ink outline-none"
      />
      <button
        type="submit"
        class="rounded-r-sm border-none bg-mdpva-ink px-6 py-4 font-sans text-sm font-semibold tracking-wider text-mdpva-cream uppercase transition-colors hover:bg-black"
      >
        Search
      </button>
    </form>
  </div>
</section>
