---
import { getCollection } from "astro:content";

const slides = (await getCollection("heroSlides")).sort((a, b) => a.data.order - b.data.order);
---

<section class="group relative h-[clamp(540px,68vh,720px)] bg-mdpva-ink lg:h-[clamp(520px,82vh,860px)]" data-hero-carousel>
  {
    slides.map((slide, i) => (
      <div
        class="absolute inset-0 flex items-start justify-start overflow-hidden transition-opacity duration-700"
        data-slide
        data-index={i}
        style={i === 0 ? "" : "opacity:0"}
      >
        {/* Whole image, anchored top on mobile / left on desktop. A mask fades
            only the image's trailing edge (bottom on mobile, right on desktop)
            into the dark canvas, so the hard seam is hidden without darkening
            the rest of the photo. */}
        <img
          src={slide.data.image}
          alt={slide.data.headline}
          class="h-auto w-full max-h-full max-w-full object-cover object-top brightness-[0.82] [-webkit-mask-image:linear-gradient(to_top,transparent_0%,#000_16%)] [mask-image:linear-gradient(to_top,transparent_0%,#000_16%)] lg:h-full lg:w-auto lg:object-left lg:[-webkit-mask-image:linear-gradient(to_left,transparent_0%,#000_15%)] lg:[mask-image:linear-gradient(to_left,transparent_0%,#000_15%)]"
          loading={i === 0 ? "eager" : "lazy"}
        />
        {/* Localized darken behind the text only (not a big gradient over the photo) */}
        <div class="absolute inset-0 bg-[linear-gradient(to_top,rgba(14,14,13,0.92)_0%,rgba(14,14,13,0.74)_30%,rgba(14,14,13,0.45)_54%,rgba(14,14,13,0.22)_70%,transparent_84%)] lg:hidden" />
        <div class="absolute inset-0 hidden bg-[linear-gradient(to_left,rgba(14,14,13,0.94)_0%,rgba(14,14,13,0.72)_30%,rgba(14,14,13,0.35)_50%,transparent_66%)] lg:block" />
      </div>
    ))
  }

  {/* Top scrim so the nav bar stays legible over bright photos */}
  <div class="pointer-events-none absolute inset-x-0 top-0 h-40 bg-gradient-to-b from-[rgba(14,14,13,0.6)] via-[rgba(14,14,13,0.2)] to-transparent"></div>

  <div class="absolute inset-x-0 bottom-0 px-5 pb-16 sm:px-8 lg:px-16 lg:pb-22">
    <div class="ml-auto flex max-w-[560px] flex-col items-start xl:max-w-[680px] 2xl:max-w-[880px]">
      <div class="grid">
        {
          slides.map((slide, i) => (
            <div
              data-slide-text
              data-index={i}
              class="col-start-1 row-start-1 flex flex-col items-start gap-4 transition-opacity duration-500"
              style={i === 0 ? "" : "opacity:0; pointer-events:none;"}
              aria-hidden={i === 0 ? "false" : "true"}
            >
              <div class="text-xs font-semibold tracking-[0.22em] text-mdpva-gold uppercase">{slide.data.eyebrow}</div>
              <h1 class="text-pretty font-serif text-[clamp(34px,3.4vw,58px)] leading-[1.08] font-normal text-mdpva-cream 2xl:text-[clamp(58px,3.4vw,72px)]">
                {slide.data.headline}
              </h1>
              <p class="max-w-[480px] text-[clamp(14px,1.4vw,16px)] leading-relaxed text-mdpva-cream/80">
                {slide.data.description}
              </p>
            </div>
          ))
        }
      </div>
      <div class="mt-6 flex w-full flex-nowrap gap-2.5 lg:w-auto lg:gap-3">
        <a
          href="/membership#join"
          class="flex-1 rounded-sm bg-mdpva-accent px-4 py-3 text-center text-[12px] font-semibold tracking-wider text-mdpva-cream uppercase whitespace-nowrap transition-colors hover:bg-mdpva-accent-hover lg:flex-none lg:px-6 lg:text-[13px]"
        >
          Become a Member
        </a>
        <a
          href="/gallery#gallery"
          class="flex-1 rounded-sm border border-mdpva-cream/50 px-4 py-3 text-center text-[12px] font-semibold tracking-wider text-mdpva-cream uppercase whitespace-nowrap transition-colors hover:bg-white/10 lg:flex-none lg:px-6 lg:text-[13px]"
        >
          Explore Gallery
        </a>
      </div>
    </div>
  </div>

  {
    slides.length > 1 && (
      <div class="absolute inset-x-0 bottom-5 flex items-center justify-center gap-4 px-5 sm:bottom-7">
        <button
          type="button"
          data-hero-prev
          aria-label="Previous slide"
          class="flex h-7 w-7 items-center justify-center rounded-full border border-mdpva-cream/40 text-xs text-mdpva-cream transition-colors hover:border-mdpva-cream lg:hidden"
        >
          ←
        </button>
        <div class="flex gap-2" data-hero-dots role="tablist" aria-label="Hero slides">
          {slides.map((slide, i) => (
            <button
              type="button"
              data-hero-dot
              data-index={i}
              role="tab"
              aria-selected={i === 0 ? "true" : "false"}
              aria-label={`Show slide ${i + 1}: ${slide.data.eyebrow}`}
              class="relative h-2 w-2 overflow-hidden rounded-full bg-mdpva-cream/40 transition-all data-[active=true]:w-7"
              data-active={i === 0}
            >
              <span data-dot-fill class="absolute inset-y-0 left-0 block w-full origin-left bg-mdpva-cream"></span>
            </button>
          ))}
        </div>
        <button
          type="button"
          data-hero-next
          aria-label="Next slide"
          class="flex h-7 w-7 items-center justify-center rounded-full border border-mdpva-cream/40 text-xs text-mdpva-cream transition-colors hover:border-mdpva-cream lg:hidden"
        >
          →
        </button>
      </div>
    )
  }
</section>

<script>
  const root = document.querySelector<HTMLElement>("[data-hero-carousel]");
  if (root) {
    const slideEls = Array.from(root.querySelectorAll<HTMLElement>("[data-slide]"));
    const textEls = Array.from(root.querySelectorAll<HTMLElement>("[data-slide-text]"));
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>("[data-hero-dot]"));
    const prevBtn = root.querySelector<HTMLButtonElement>("[data-hero-prev]");
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-hero-next]");

    let current = 0;
    let timer: ReturnType<typeof setInterval> | undefined;
    const AUTOPLAY_MS = 6000;

    const show = (index: number) => {
      current = (index + slideEls.length) % slideEls.length;

      slideEls.forEach((el, i) => {
        el.style.opacity = i === current ? "1" : "0";
      });

      textEls.forEach((el, i) => {
        el.style.opacity = i === current ? "1" : "0";
        el.style.pointerEvents = i === current ? "" : "none";
        el.setAttribute("aria-hidden", String(i !== current));
        // Re-trigger the staggered rise-in animation on the active slide's text
        el.classList.remove("is-current");
        if (i === current) {
          void el.offsetWidth; // force reflow so the animation restarts
          el.classList.add("is-current");
        }
      });

      dots.forEach((dot, i) => {
        dot.dataset.active = String(i === current);
        dot.setAttribute("aria-selected", String(i === current));
      });

      // Restart the active dot's fill animation
      const activeFill = dots[current]?.querySelector<HTMLElement>("[data-dot-fill]");
      if (activeFill) {
        activeFill.style.animation = "none";
        void activeFill.offsetWidth;
        activeFill.style.animation = "";
      }
    };

    const start = () => {
      stop();
      if (slideEls.length > 1) timer = setInterval(() => show(current + 1), AUTOPLAY_MS);
    };

    const stop = () => {
      if (timer) clearInterval(timer);
    };

    prevBtn?.addEventListener("click", () => {
      show(current - 1);
      start();
    });

    nextBtn?.addEventListener("click", () => {
      show(current + 1);
      start();
    });

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        show(Number(dot.dataset.index));
        start();
      });
    });

    show(0);
    start();
  }
</script>
