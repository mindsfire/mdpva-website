---
import { getCollection } from "astro:content";

const items = (await getCollection("press"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const dateFmt = new Intl.DateTimeFormat("en-IN", { day: "2-digit", month: "short", year: "numeric" });
---

<section class="border-t border-mdpva-border bg-mdpva-white px-5 py-[clamp(56px,9vw,110px)] sm:px-8 lg:px-16">
  <div class="mx-auto max-w-[1200px]">
    <div class="mb-8 flex flex-wrap items-end justify-between gap-6" data-reveal>
      <div>
        <div class="mb-3.5 text-xs font-semibold tracking-[0.22em] text-mdpva-accent uppercase">
          In the Media
        </div>
        <h2 class="font-serif text-[clamp(26px,3.2vw,40px)] font-normal">MDPVA in the news</h2>
      </div>
      <a href="/press" class="border-b border-current pb-0.5 text-sm font-semibold tracking-wide">
        All press coverage →
      </a>
    </div>
    <div
      class="grid gap-6"
      style="grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));"
    >
      {
        items.map((item, i) => (
          <a
            href={item.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col border border-mdpva-border-alt bg-mdpva-white transition-shadow duration-300 hover:shadow-lg"
            data-reveal
            style={`--reveal-delay:${i * 90}ms`}
          >
            <div class="aspect-[4/3] overflow-hidden bg-mdpva-border-tile">
              <img
                src={item.data.thumbnail}
                alt=""
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
              />
            </div>
            <div class="flex flex-1 flex-col gap-3 p-6">
              <div class="flex items-center justify-between gap-3">
                <span class="bg-mdpva-accent/10 px-2.5 py-1 text-[11px] font-semibold tracking-[0.12em] text-mdpva-accent uppercase">
                  {item.data.publication}
                </span>
                <span class="text-[12px] whitespace-nowrap text-mdpva-muted">
                  {dateFmt.format(item.data.date)}
                </span>
              </div>
              <h3 class="text-pretty flex-1 font-serif text-[19px] leading-snug font-medium text-mdpva-ink transition-colors group-hover:text-mdpva-accent">
                {item.data.title}
              </h3>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
