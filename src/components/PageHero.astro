---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="bg-mdpva-ink px-5 pt-32 pb-16 text-mdpva-cream sm:px-8 lg:px-16 lg:pt-40 lg:pb-20">
  <div class="mx-auto max-w-[1200px]" data-reveal>
    <div class="mb-4 text-xs font-semibold tracking-[0.22em] text-mdpva-gold uppercase">
      {eyebrow}
    </div>
    <h1 class="text-pretty max-w-[780px] font-serif text-[clamp(32px,4.4vw,56px)] leading-tight font-normal">
      {title}
    </h1>
    {
      description && (
        <p class="mt-5 max-w-[620px] text-base leading-relaxed text-mdpva-cream/70">{description}</p>
      )
    }
  </div>
</section>
