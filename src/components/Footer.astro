---
const quickLinks = [
  { href: "/about", label: "About & Legacy" },
  { href: "/board", label: "Board of Directors" },
  { href: "/gallery", label: "Member Gallery" },
  { href: "/events", label: "Events & Workshops" },
  { href: "/blog", label: "Blog" },
  { href: "/press", label: "In the Media" },
  { href: "/membership", label: "Membership" },
];
---

<footer id="join" class="bg-mdpva-ink px-5 pt-14 pb-10 text-mdpva-cream sm:px-8 sm:pt-20 lg:px-16 lg:pt-24">
  <div class="mx-auto max-w-[1200px]">
    <div
      class="grid gap-8 border-b border-mdpva-border-dark pb-12 lg:gap-16"
      style="grid-template-columns: repeat(auto-fit, minmax(min(100%, 220px), 1fr));"
      data-reveal
    >
      <div class="flex flex-col gap-4">
        <div class="font-serif text-2xl font-semibold tracking-wide">MDPVA</div>
        <p class="max-w-[300px] text-sm leading-relaxed text-mdpva-cream/65">
          Mysuru District Photographers and Videographers Association ®. Representing the
          district's professional image-makers since 2000.
        </p>
        <div class="mt-1 flex gap-3">
          <a
            href="https://facebook.com/mdpva"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="MDPVA on Facebook"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-mdpva-cream/25 text-mdpva-cream/70 transition-colors hover:border-mdpva-gold hover:text-mdpva-gold"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.25-1.5 1.55-1.5h1.65V3.6c-.3-.04-1.27-.13-2.4-.13-2.37 0-4 1.45-4 4.1v2.32H7.6V13h2.7v8h3.2z" />
            </svg>
          </a>
          <a
            href="https://instagram.com/mdpva"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="MDPVA on Instagram"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-mdpva-cream/25 text-mdpva-cream/70 transition-colors hover:border-mdpva-gold hover:text-mdpva-gold"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <circle cx="12" cy="12" r="4.2" />
              <circle cx="17.4" cy="6.6" r="1.1" fill="currentColor" stroke="none" />
            </svg>
          </a>
        </div>
      </div>
      <div class="flex flex-col gap-3">
        <div class="mb-1 text-[11px] font-semibold tracking-[0.18em] text-mdpva-muted uppercase">
          Quick links
        </div>
        {
          quickLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm text-mdpva-cream/79 transition-colors hover:text-mdpva-cream"
            >
              {link.label}
            </a>
          ))
        }
      </div>
      <div class="flex flex-col gap-3">
        <div class="text-[11px] font-semibold tracking-[0.18em] text-mdpva-muted uppercase">
          Contact
        </div>
        <div class="text-sm leading-relaxed text-mdpva-cream/79">
          #224, Narayana Shastri Road,<br />next to Mahalakshmi Temple,<br />K.R. Mohalla, Mysuru
          – 570024
        </div>
        <a href="mailto:office@mdpva.in" class="text-sm text-mdpva-cream/79 transition-colors hover:text-mdpva-cream">
          office@mdpva.in
        </a>
        <a href="tel:+918212400000" class="text-sm text-mdpva-cream/79 transition-colors hover:text-mdpva-cream">
          +91 821 240 0000
        </a>
      </div>
      <div class="flex flex-col items-start gap-4">
        <div class="text-[11px] font-semibold tracking-[0.18em] text-mdpva-muted uppercase">
          Join the association
        </div>
        <p class="text-sm leading-relaxed text-mdpva-cream/65">
          Working photographer or videographer in Mysuru district? Get certified, listed, and
          connected.
        </p>
        <a
          href="/membership"
          class="inline-block rounded-sm bg-mdpva-accent px-6 py-3.5 text-[13px] font-semibold tracking-wider text-mdpva-cream uppercase transition-colors hover:bg-mdpva-accent-hover"
        >
          Become a Member
        </a>
      </div>
    </div>
    <div class="flex flex-wrap justify-between gap-4 pt-6 text-xs text-mdpva-muted">
      <span>© 2026 Mysuru District Photographers and Videographers Association ®</span>
      <span>
        Developed by{" "}
        <a
          href="https://www.mindsfire.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-mdpva-cream/70 transition-colors hover:text-mdpva-gold"
        >
          Mindsfire Private Limited
        </a>
      </span>
    </div>
  </div>
</footer>
